# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# optional: use an OpenAI-compatible API instead of Vercel AI Gateway
# examples:
# OPENAI_COMPATIBLE_BASE_URL=https://your-provider.example.com/v1
# when OPENAI_COMPATIBLE_BASE_URL is set, the app will auto-load models from ${OPENAI_COMPATIBLE_BASE_URL}/models
# OPENAI_COMPATIBLE_MODELS remains an optional fallback override if auto-discovery fails
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODELS=
OPENAI_COMPATIBLE_DEFAULT_MODEL=
OPENAI_COMPATIBLE_TITLE_MODEL=
