# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# OpenAI-compatible API credentials
# Example (OpenAI official): OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=****
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: override models endpoint if your compatible provider uses a custom path
# OPENAI_MODELS_API_URL=https://api.openai.com/v1/models

# Optional defaults used when API model list is unavailable
# NEXT_PUBLIC_DEFAULT_CHAT_MODEL=gpt-4o-mini
# NEXT_PUBLIC_TITLE_MODEL=gpt-4o-mini

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****
